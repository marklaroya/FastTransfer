{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastTransfer Desktop",
  "version": "0.1.0",
  "identifier": "com.fasttransfer.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FastTransfer Desktop",
        "width": 1240,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
